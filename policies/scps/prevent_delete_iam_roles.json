{
    "Version": "2012-10-17",
    "Statement": [
        {
            "Sid": "PreventDeleteIAMRoles",
            "Effect": "Deny",
            "Action": [
                "iam:DeleteRole",
                "iam:DeleteRolePolicy",
                "iam:DetachRolePolicy"
            ],
            "Resource": "*"
        }
    ]
}